// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  // url      = env("DATABASE_URL")
}

model Products {
  id          String       @id @default(uuid())
  name        String       @unique
  brand       String
  price       Float
  discount    Float
  description String
  image       String
  attributes  Attributes[]

  reviews   Reviews[]         @relation("ReviewProductId")
  analytics ProducsAnalytics? @relation("ProductAnalytics")
  analyticsEvents AnalyticsEvent[]
}

model Attributes {
  productsId      String          @id
  Products        Products        @relation(fields: [productsId], references: [id])
  type            ProductType
  category        ProductCategory
  color           ProductColor
  size            Size
  brand           String?
  material        String?
  countryOfOrigin String?
  weight          Float?
}


model User {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  orders Order[]

  reviewsById   Reviews[] @relation("UserById")
  reviewsByName Reviews[] @relation("UserByName")
  analyticsEvents AnalyticsEvent[]
}

model Order {
  id             String         @id @default(uuid())
  userId         String?
  items          OrderItem[]    @relation("OrderToOrderItem")
  promoCodeId    String?
  subtotal       Float          @default(0)
  promoDiscountTotal Float      @default(0)
  total          Float
  deliveryMethod DeliveryMethod
  address        String
  email          String
  status         OrderStatus @default(Accepted)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt

  user User? @relation(fields: [userId], references: [id])
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id])
}

enum OrderStatus {
  Pending
  Delivered
  Declined
  Canceled
  Received
  Processing
  Accepted
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  originalPrice Float @default(0)
  discountAmount Float @default(0)
  price     Float

  order Order @relation(fields: [orderId], references: [id], name: "OrderToOrderItem")
}

model PromoCode {
  id                   String                 @id @default(uuid())
  code                 String                 @unique
  discountType         PromoCodeDiscountType
  discountValue        Float
  usageLimit           Int?
  usedCount            Int                    @default(0)
  isActive             Boolean                @default(true)
  isInfinite           Boolean                @default(false)
  expiresAt            DateTime?
  minProductPrice      Float?
  maxProductPrice      Float?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @default(now()) @updatedAt
  applicableProductTypes PromoCodeProductType[]
  orders               Order[]
}

model PromoCodeProductType {
  id          String      @id @default(uuid())
  promoCodeId String
  type        ProductType
  promoCode   PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, type])
}

model Reviews {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  userName    String
  reviewTitle String
  rewiew      String
  stars       Int
  createdAt   DateTime @default(now())

  userID   User     @relation("UserById", fields: [userId], references: [id])
  userNAME User     @relation("UserByName", fields: [userName], references: [name])
  product  Products @relation("ReviewProductId", fields: [productId], references: [id])

  @@unique([userId, productId])
}

enum Role {
  admin
  user
  manager
  support
  system
}

enum ProductType {
  hoodie
  sweatshirt
  shirt
  tshirt
}

enum ProductCategory {
  male
  female
}

enum ProductColor {
  black
  white
  yellow
  pink
  brown
  blue
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
}

enum DeliveryMethod {
  Courier
  Pickup
}

enum PromoCodeDiscountType {
  Percentage
  FixedAmount
}

model ProducsAnalytics {
  id        String @id @default(uuid())
  productId String @unique
  views     Int
  clicks    Int
  orders    Int
  reviews   Int
  maxRating Float
  minRating Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Products @relation("ProductAnalytics", fields: [productId], references: [id])
}

/** Raw user/product/session events for analytics (stored via analytics-service → database microservice). */
model AnalyticsEvent {
  id          String   @id @default(uuid())
  name        String
  sessionId   String?
  userId      String?
  productId   String?
  path        String?
  durationMs  Int?
  payload     Json?
  clientId    String?
  createdAt   DateTime @default(now())

  user    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Products? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([createdAt])
  @@index([sessionId])
}
