{
  "extends": "./tsconfig.json",
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts"
  ],
  "compilerOptions": {
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": true,
    "paths": {
      "@prisma/client": ["./prisma/generated/index"],
      "@packages/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src"]
}