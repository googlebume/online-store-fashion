{
  "name": "online-store-fashion-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:frontend": "npm run start:frontend --prefix frontend",
    "start:backend": "npm run start:backend --prefix backend",
    "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:frontend": "npm run build:frontend --prefix frontend",
    "prisma:generate": "npm run prisma:generate --prefix backend",
    "prisma": "npm run prisma --prefix backend",
    "firstly": "npm install --prefix backend && npm install --prefix frontend && npm run prisma:generate && npm run start:dev && npm run prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
