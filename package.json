{
  "name": "online-store-fashion-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:frontend": "cd frontend && npm run start:frontend",
    "start:backend": "cd backend && npm run start:backend",
    "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:frontend": "cd frontend && npm run build:frontend",
    "prisma:generate": "cd backend && npm run prisma:generate",
    "prisma": "cd backend && npm run prisma",
    "firstly": "cd backend && npm install && npm run prisma:generate && cd ..\\frontend && npm install && cd .. && npm run start:dev && npm run prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
